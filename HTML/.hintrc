{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-charset-utf-8": "off",
    "axe/text-alternatives": [
      "default",
      {
        "document-title": "off",
        "image-alt": "off",
        "frame-title": "off"
      }
    ],
    "meta-viewport": "off",
    "axe/language": "off",
    "no-inline-styles": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "axe/time-and-media": [
      "default",
      {
        "blink": "off"
      }
    ]
  }
}